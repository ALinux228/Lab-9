<Window x:Class="MoneyCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор денег" 
        Height="450" 
        Width="500"
        WindowStartupLocation="CenterScreen" Icon="/dollar.png">
    <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                  VerticalScrollBarVisibility="Auto">
        <Grid>
        
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="600"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Margin="10" Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Калькулятор рублей и копеек"
                           FontSize="18" 
                           FontWeight="Bold"
                           Foreground="Purple"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <GroupBox Grid.Row="1" 
                          Header="Создать сумму" 
                          Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                Margin="5">
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <Label Content="Рубли:" Width="50"/>
                            <TextBox x:Name="txtRubles" 
                                     Width="100" 
                                     Text="0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="5">
                            <Label Content="Копейки:" Width="60"/>
                            <TextBox x:Name="txtKopeks" 
                                     Width="100" 
                                     Text="0"/>
                        </StackPanel>

                        <Button x:Name="btnCreate" 
                                Content="Создать"
                                Width="80"
                                Margin="10,0,0,0"
                                Background="Plum"
                                
                                BorderThickness="0"
                                Click="BtnCreate_Click"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="2" 
                          Header="Текущая сумма" 
                          Margin="0,0,0,10">
                    <TextBox x:Name="txtCurrentMoney" 
                             FontSize="16" 
                             FontWeight="Bold"
                             TextAlignment="Center"
                             IsReadOnly="True"
                             Background="Lavender"
                             Foreground="Purple"
                             BorderThickness="0"
                             Margin="10"
                             Padding="10"/>
                </GroupBox>

                <GroupBox Grid.Row="3" 
                          Header="Операции" 
                          Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center">
                            <Button x:Name="btnIncrement" 
                                    Content="Добавить копейку"
                                    Width="130"
                                    Margin="5"
                                    Padding="10,5"
                                    Background="LightSkyBlue"
                                    BorderThickness="0"
                                    Click="BtnIncrement_Click"/>

                            <Button x:Name="btnDecrement" 
                                    Content="Вычесть копейку"
                                    Width="130"
                                    Margin="5"
                                    Padding="10,5"
                                    Background="Plum"
                                    BorderThickness="0"
                                    Click="BtnDecrement_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center"
                                    Margin="0,10,0,0">
                            <TextBox x:Name="txtRublesAmount" 
                                     Width="80"
                                     Text="0"
                                     Margin="5"/>

                            <Button x:Name="btnAddRubles" 
                                    Content="+ рублей"
                                    Width="90"
                                    Margin="5"
                                    Background="LightSkyBlue"
                                    BorderThickness="0"
                                    Click="BtnAddRubles_Click"/>

                            <Button x:Name="btnSubtractRubles" 
                                    Content="- рублей"
                                    Width="90"
                                    Margin="5"
                                    Background="Plum"
                                    BorderThickness="0"
                                    Click="BtnSubtractRubles_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center"
                                    Margin="0,10,0,0">
                            <TextBox x:Name="txtKopeksAmount" 
                                     Width="80"
                                     Text="0"
                                     Margin="5"/>

                            <Button x:Name="btnAddKopeks" 
                                    Content="+ копеек"
                                    Width="90"
                                    Margin="5"
                                    Background="LightSkyBlue"
                                    BorderThickness="0"
                                    Click="BtnAddKopeks_Click"/>

                            <Button x:Name="btnSubtractKopeks" 
                                    Content="- копеек"
                                    Width="90"
                                    Margin="5"
                                    Background="Plum"
                                    BorderThickness="0"
                                    Click="BtnSubtractKopeks_Click"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="4" 
                          Header="Конвертация" 
                          Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                Margin="10">
                        
                        <Button x:Name="btnToDouble" 
                                Content="Преобразовать в Double"
                                Width="180"
                                Padding="10,5"
                                Background="Lavender"
                                BorderThickness="0"
                                Margin="0,0,10,0" 
                                Click="BtnToDouble_Click"/>
                        
                        <Button x:Name="btnToUint" 
                                Content="Преобразовать в Uint"
                                Width="180"
                                Padding="10,5"
                                Background="Lavender"
                                BorderThickness="0"
                                Click="BtnToUint_Click"/>
                        
                    </StackPanel>
                </GroupBox>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>